{
  "name": "seedrock",
  "version": "1.2.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "license": "MIT",
  "description": "Open-source procedural rock & cliff generator for Three.js (WebGPU).",
  "homepage": "https://github.com/reed-soul/SeedRock",
  "repository": {
    "type": "git",
    "url": "https://github.com/reed-soul/SeedRock.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 5390",
    "textures": "node scripts/texture/generate-procedural.mjs",
    "textures:ingest": "node scripts/texture/ingest-ai.mjs",
    "textures:prompts": "node scripts/texture/ai-prompts.mjs",
    "textures:derive": "node scripts/texture/derive-pbr.mjs",
    "test": "node --test tests/**/*.test.js"
  },
  "dependencies": {
    "lil-gui": "^0.21.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "sharp": "^0.35.3",
    "vite": "^8.1.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
